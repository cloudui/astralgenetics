---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Astral Genetics — One RNA. Multiple Functions. Real Genetic Medicine. A proprietary RNA All-in-One platform for next-generation therapeutics." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;400;500;600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-warm-50 text-warm-800 antialiased">
    <slot />
  </body>
</html>

<style is:global>
  html {
    scrollbar-color: #3d64f5 #f8f6f3;
  }

  ::selection {
    background: rgba(61, 100, 245, 0.15);
  }

  /* Smooth fade-in for sections */
  .fade-section {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .fade-section.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
