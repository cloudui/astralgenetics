---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Astral Genetics — One RNA. Multiple Functions. Real Genetic Medicine. A proprietary RNA All-in-One platform integrating gene editing, epigenetic modulation, and protein replacement into a single deliverable molecule." />
    <meta name="keywords" content="RNA therapeutics, gene editing, CRISPR, LNP delivery, epigenetic editing, genetic medicine, RNA platform, Astral Genetics" />
    <meta name="author" content="Astral Genetics" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="A proprietary RNA All-in-One platform integrating multiple gene editing and regulatory components into a single, deliverable molecule." />
    <meta property="og:site_name" content="Astral Genetics" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="One RNA. Multiple Functions. Real Genetic Medicine." />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;400;500;600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-warm-50 text-warm-800 antialiased">
    <slot />
  </body>
</html>

<style is:global>
  html {
    scrollbar-color: #5e8ac7 #f8f6f3;
  }

  ::selection {
    background: rgba(94, 138, 199, 0.2);
  }

  /* Smooth fade-in for sections */
  .fade-section {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .fade-section.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
