---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Astral Genetics — RNA All-in-One Platform">
  <!-- NAV -->
  <nav class="fixed top-0 w-full z-50 bg-warm-50/80 backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="h-20 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-sm font-semibold text-white">AG</div>
          <span class="text-sm font-medium tracking-wider uppercase text-warm-700">Astral Genetics</span>
        </a>
        <div class="hidden md:flex items-center gap-10 text-[13px] tracking-wide text-warm-500">
          <a href="#platform" class="hover:text-warm-900 transition-colors">Platform</a>
          <a href="#capabilities" class="hover:text-warm-900 transition-colors">Science</a>
          <a href="#applications" class="hover:text-warm-900 transition-colors">Applications</a>
          <a href="#company" class="hover:text-warm-900 transition-colors">Company</a>
          <a href="#contact" class="ml-2 px-5 py-2 rounded-full bg-brand-600 text-white hover:bg-brand-700 transition-colors">Partner With Us</a>
        </div>
        <button id="menu-toggle" class="md:hidden text-warm-600 hover:text-warm-900" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="hidden md:hidden border-t border-warm-200 bg-warm-50/95 backdrop-blur-xl">
      <div class="px-6 py-5 flex flex-col gap-4 text-sm text-warm-600">
        <a href="#platform" class="hover:text-warm-900">Platform</a>
        <a href="#capabilities" class="hover:text-warm-900">Science</a>
        <a href="#applications" class="hover:text-warm-900">Applications</a>
        <a href="#company" class="hover:text-warm-900">Company</a>
        <a href="#contact" class="mt-2 text-center px-5 py-2.5 rounded-full bg-brand-600 text-white">Partner With Us</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-end overflow-hidden pb-24 pt-32 lg:pt-0 lg:items-center">
    <!-- Subtle background -->
    <div class="absolute inset-0 bg-gradient-to-b from-brand-50/40 via-warm-50 to-warm-50"></div>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-10 w-full">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Left: text -->
        <div>
          <p class="text-brand-600 text-sm font-medium tracking-widest uppercase mb-6">RNA Therapeutics Platform</p>

          <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-warm-950 mb-8">
            One RNA.<br />
            Multiple functions.<br />
            <em class="text-brand-600">Real medicine.</em>
          </h1>

          <p class="text-lg text-warm-500 max-w-lg leading-relaxed mb-10">
            A proprietary platform that integrates multiple gene editing and regulatory components into a single, deliverable RNA molecule — paired with large-fragment delivery systems engineered to overcome the limits of conventional genetic medicine.
          </p>

          <div class="flex flex-wrap gap-4">
            <a href="#platform" class="px-7 py-3.5 rounded-full bg-brand-600 text-white font-medium hover:bg-brand-700 transition-all hover:shadow-lg hover:shadow-brand-200">
              Explore Platform
            </a>
            <a href="#capabilities" class="px-7 py-3.5 rounded-full border border-warm-300 text-warm-600 hover:border-warm-400 hover:text-warm-800 font-medium transition-all">
              View Science
            </a>
          </div>
        </div>

        <!-- Right: hero illustration — RNA molecule SVG -->
        <div class="hidden lg:flex items-center justify-center">
          <div class="relative w-full max-w-md aspect-square">
            <!-- Outer glow -->
            <div class="absolute inset-0 bg-brand-100/50 rounded-full blur-[60px]"></div>
            <!-- RNA molecule illustration -->
            <svg class="relative w-full h-full" viewBox="0 0 400 400" fill="none">
              <!-- Central helix -->
              <path d="M160,40 Q260,80 160,140 Q60,200 160,260 Q260,320 160,380" stroke="url(#helix1)" stroke-width="2" fill="none" opacity="0.7" />
              <path d="M240,40 Q140,80 240,140 Q340,200 240,260 Q140,320 240,380" stroke="url(#helix2)" stroke-width="2" fill="none" opacity="0.7" />
              <!-- Base pair rungs -->
              <line x1="175" y1="60" x2="225" y2="60" stroke="#9ac3a4" stroke-width="1.5" opacity="0.5" />
              <line x1="145" y1="110" x2="255" y2="110" stroke="#9ac3a4" stroke-width="1.5" opacity="0.4" />
              <line x1="165" y1="160" x2="235" y2="160" stroke="#9ac3a4" stroke-width="1.5" opacity="0.5" />
              <line x1="145" y1="210" x2="255" y2="210" stroke="#9ac3a4" stroke-width="1.5" opacity="0.4" />
              <line x1="175" y1="260" x2="225" y2="260" stroke="#9ac3a4" stroke-width="1.5" opacity="0.5" />
              <line x1="145" y1="310" x2="255" y2="310" stroke="#9ac3a4" stroke-width="1.5" opacity="0.4" />
              <line x1="175" y1="355" x2="225" y2="355" stroke="#9ac3a4" stroke-width="1.5" opacity="0.5" />

              <!-- Functional component nodes -->
              <circle cx="160" cy="140" r="18" fill="none" stroke="#4d7c5e" stroke-width="1.5" opacity="0.6" />
              <circle cx="160" cy="140" r="4" fill="#4d7c5e" opacity="0.6" />
              <text x="160" y="143" text-anchor="middle" fill="#4d7c5e" font-size="7" font-family="DM Sans" opacity="0.5" class="uppercase tracking-widest"></text>

              <circle cx="240" cy="200" r="22" fill="none" stroke="#4d7c5e" stroke-width="1.5" opacity="0.6" />
              <circle cx="240" cy="200" r="5" fill="#4d7c5e" opacity="0.6" />

              <circle cx="160" cy="260" r="16" fill="none" stroke="#4d7c5e" stroke-width="1.5" opacity="0.6" />
              <circle cx="160" cy="260" r="3.5" fill="#4d7c5e" opacity="0.6" />

              <!-- Orbiting particles -->
              <circle cx="300" cy="120" r="2" fill="#6da67b" opacity="0.4">
                <animate attributeName="cy" values="120;130;120" dur="4s" repeatCount="indefinite" />
              </circle>
              <circle cx="100" cy="280" r="1.5" fill="#6da67b" opacity="0.3">
                <animate attributeName="cy" values="280;270;280" dur="5s" repeatCount="indefinite" />
              </circle>
              <circle cx="320" cy="300" r="2.5" fill="#9ac3a4" opacity="0.3">
                <animate attributeName="cx" values="320;330;320" dur="6s" repeatCount="indefinite" />
              </circle>
              <circle cx="80" cy="100" r="2" fill="#9ac3a4" opacity="0.25">
                <animate attributeName="cy" values="100;110;100" dur="3.5s" repeatCount="indefinite" />
              </circle>

              <!-- LNP shell (outer) -->
              <circle cx="200" cy="200" r="170" stroke="#c3dbc9" stroke-width="0.75" fill="none" opacity="0.4" stroke-dasharray="4 6" />
              <circle cx="200" cy="200" r="155" stroke="#c3dbc9" stroke-width="0.5" fill="none" opacity="0.25" stroke-dasharray="2 8" />

              <!-- Gradient defs -->
              <defs>
                <linearGradient id="helix1" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%" stop-color="#6da67b" stop-opacity="0.3" />
                  <stop offset="50%" stop-color="#4d7c5e" stop-opacity="0.8" />
                  <stop offset="100%" stop-color="#6da67b" stop-opacity="0.3" />
                </linearGradient>
                <linearGradient id="helix2" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%" stop-color="#9ac3a4" stop-opacity="0.3" />
                  <stop offset="50%" stop-color="#6da67b" stop-opacity="0.7" />
                  <stop offset="100%" stop-color="#9ac3a4" stop-opacity="0.3" />
                </linearGradient>
              </defs>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER — thin line -->
  <div class="max-w-7xl mx-auto px-6 lg:px-10"><div class="h-px bg-warm-200"></div></div>

  <!-- PLATFORM OVERVIEW -->
  <section id="platform" class="fade-section relative py-28 sm:py-36">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-12 gap-16 lg:gap-20">
        <!-- Left: section intro -->
        <div class="lg:col-span-5">
          <p class="text-brand-600 text-xs font-medium tracking-widest uppercase mb-4">Platform</p>
          <h2 class="font-serif text-4xl sm:text-5xl leading-[1.1] tracking-tight text-warm-950 mb-6">
            A new architecture for genetic medicine
          </h2>
          <p class="text-warm-500 text-lg leading-relaxed">
            Traditional approaches fragment complexity across multiple delivery vectors and editing systems. Our platform unifies them into a single molecule.
          </p>
        </div>

        <!-- Right: two stacked items -->
        <div class="lg:col-span-7 space-y-8">
          <!-- RNA All-in-One -->
          <div class="relative border border-warm-200 rounded-2xl bg-white p-8 sm:p-10">
            <div class="flex items-start gap-6">
              <!-- Icon -->
              <div class="shrink-0 w-14 h-14 rounded-2xl bg-brand-50 flex items-center justify-center">
                <svg class="w-7 h-7 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="font-serif text-2xl text-warm-900 mb-3">RNA All-in-One</h3>
                <p class="text-warm-500 leading-relaxed mb-5">A single IVT RNA encoding all required functional components for coordinated therapeutic action.</p>
                <div class="grid sm:grid-cols-3 gap-4 text-sm text-warm-600">
                  <div class="flex items-start gap-2">
                    <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"></span>
                    Multi-component integration in one transcript
                  </div>
                  <div class="flex items-start gap-2">
                    <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"></span>
                    Synchronized intracellular release
                  </div>
                  <div class="flex items-start gap-2">
                    <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"></span>
                    Reduced variability
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- LNP Engine -->
          <div class="relative border border-warm-200 rounded-2xl bg-white p-8 sm:p-10">
            <div class="flex items-start gap-6">
              <div class="shrink-0 w-14 h-14 rounded-2xl bg-brand-50 flex items-center justify-center">
                <svg class="w-7 h-7 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="font-serif text-2xl text-warm-900 mb-3">Large-Payload LNP Engine</h3>
                <p class="text-warm-500 leading-relaxed mb-5">A delivery system purpose-built for next-generation RNA therapeutics.</p>
                <div class="grid sm:grid-cols-3 gap-4 text-sm text-warm-600">
                  <div class="flex items-start gap-2">
                    <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"></span>
                    Large RNA payloads (9kb+)
                  </div>
                  <div class="flex items-start gap-2">
                    <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"></span>
                    Hepatic targeting &amp; systemic delivery
                  </div>
                  <div class="flex items-start gap-2">
                    <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"></span>
                    Scalable for clinical translation
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS — editorial layout -->
  <section class="fade-section relative py-28 sm:py-36 bg-brand-50/40">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <p class="text-brand-600 text-xs font-medium tracking-widest uppercase mb-4">Process</p>
      <h2 class="font-serif text-4xl sm:text-5xl leading-[1.1] tracking-tight text-warm-950 mb-20">
        From design to execution
      </h2>

      <div class="grid md:grid-cols-3 gap-px bg-warm-200 rounded-2xl overflow-hidden">
        <div class="bg-white p-10 sm:p-12">
          <div class="font-serif text-6xl text-brand-200 mb-6">1</div>
          <h3 class="font-serif text-2xl text-warm-900 mb-3">Encode</h3>
          <p class="text-warm-500 leading-relaxed">Multiple functional elements are designed within a single RNA construct, enabling coordinated multi-component activity from one molecule.</p>
        </div>
        <div class="bg-white p-10 sm:p-12">
          <div class="font-serif text-6xl text-brand-200 mb-6">2</div>
          <h3 class="font-serif text-2xl text-warm-900 mb-3">Deliver</h3>
          <p class="text-warm-500 leading-relaxed">Proprietary LNP systems transport large RNA payloads into target tissues with high efficiency and cell-type specificity.</p>
        </div>
        <div class="bg-white p-10 sm:p-12">
          <div class="font-serif text-6xl text-brand-200 mb-6">3</div>
          <h3 class="font-serif text-2xl text-warm-900 mb-3">Execute</h3>
          <p class="text-warm-500 leading-relaxed">Intracellular processing releases independent modules, enabling coordinated biological function from a single delivery event.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section id="capabilities" class="fade-section relative py-28 sm:py-36">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-12 gap-16 lg:gap-20 items-start">
        <div class="lg:col-span-4">
          <p class="text-brand-600 text-xs font-medium tracking-widest uppercase mb-4">Capabilities</p>
          <h2 class="font-serif text-4xl sm:text-5xl leading-[1.1] tracking-tight text-warm-950 mb-6">
            A versatile engine for genetic modulation
          </h2>
          <p class="text-warm-500 text-lg leading-relaxed">
            Three core modalities, unified within a single platform architecture.
          </p>
        </div>

        <div class="lg:col-span-8">
          <!-- Merged border grid like Isomorphic -->
          <div class="grid sm:grid-cols-2 gap-px bg-warm-200 rounded-2xl overflow-hidden">
            <div class="bg-white p-8 sm:p-10">
              <p class="text-brand-600 text-[11px] font-medium tracking-widest uppercase mb-5">Epigenetic Editing</p>
              <h3 class="font-serif text-xl text-warm-900 mb-3">CRISPRi / Modulation</h3>
              <p class="text-warm-500 text-sm leading-relaxed mb-5">Programmable, non-permanent control of gene expression without altering the underlying DNA sequence.</p>
              <ul class="space-y-2.5 text-sm text-warm-600">
                <li class="flex items-start gap-2.5">
                  <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"></span>
                  Multi-target silencing in one construct
                </li>
                <li class="flex items-start gap-2.5">
                  <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"></span>
                  Tumor &amp; viral transcriptional reprogramming
                </li>
              </ul>
            </div>

            <div class="bg-white p-8 sm:p-10">
              <p class="text-brand-600 text-[11px] font-medium tracking-widest uppercase mb-5">Genome Editing</p>
              <h3 class="font-serif text-xl text-warm-900 mb-3">Large Fragment Integration</h3>
              <p class="text-warm-500 text-sm leading-relaxed mb-5">Efficient modification beyond single-base editing, supporting complex genetic corrections.</p>
              <ul class="space-y-2.5 text-sm text-warm-600">
                <li class="flex items-start gap-2.5">
                  <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"></span>
                  Large genetic insertions
                </li>
                <li class="flex items-start gap-2.5">
                  <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"></span>
                  Complex mutation correction
                </li>
              </ul>
            </div>

            <div class="bg-white p-8 sm:p-10 sm:col-span-2">
              <div class="grid sm:grid-cols-2 gap-8 items-start">
                <div>
                  <p class="text-brand-600 text-[11px] font-medium tracking-widest uppercase mb-5">Protein Replacement</p>
                  <h3 class="font-serif text-xl text-warm-900 mb-3">In Vivo RNA Expression</h3>
                  <p class="text-warm-500 text-sm leading-relaxed">Direct expression of functional proteins via high-expression IVT RNA constructs, enabling therapeutic protein delivery beyond the limits of AAV.</p>
                </div>
                <div class="pt-1">
                  <!-- Placeholder for future illustration -->
                  <div class="aspect-[4/3] rounded-xl bg-brand-50/60 border border-brand-100 flex items-center justify-center">
                    <svg class="w-20 h-20 text-brand-200" viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1">
                      <circle cx="40" cy="40" r="25" stroke-dasharray="3 4" />
                      <circle cx="40" cy="40" r="12" />
                      <circle cx="40" cy="40" r="3" fill="currentColor" stroke="none" />
                      <line x1="40" y1="15" x2="40" y2="7" />
                      <line x1="40" y1="65" x2="40" y2="73" />
                      <line x1="15" y1="40" x2="7" y2="40" />
                      <line x1="65" y1="40" x2="73" y2="40" />
                    </svg>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VALIDATION -->
  <section class="fade-section relative py-28 sm:py-36 bg-warm-950 text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div>
          <p class="text-brand-300 text-xs font-medium tracking-widest uppercase mb-4">Validation</p>
          <h2 class="font-serif text-4xl sm:text-5xl leading-[1.1] tracking-tight mb-6">
            Engineered for real-world performance
          </h2>
          <p class="text-warm-400 text-lg leading-relaxed">
            Our platform is built not only for innovation — but for translatability. Every component is designed with clinical development in mind.
          </p>
        </div>

        <div class="space-y-8">
          <div class="flex items-start gap-6">
            <div class="font-serif text-4xl text-brand-400 leading-none shrink-0 w-24">>9 kb</div>
            <p class="text-warm-400 leading-relaxed">Successfully delivered large RNA constructs exceeding conventional payload limits</p>
          </div>
          <div class="h-px bg-white/10"></div>
          <div class="flex items-start gap-6">
            <div class="font-serif text-3xl text-brand-400 leading-none shrink-0 w-24 pt-0.5">Multi</div>
            <p class="text-warm-400 leading-relaxed">Demonstrated coordinated multi-component expression from a single transcript</p>
          </div>
          <div class="h-px bg-white/10"></div>
          <div class="flex items-start gap-6">
            <div class="font-serif text-3xl text-brand-400 leading-none shrink-0 w-24 pt-0.5">LNP+</div>
            <p class="text-warm-400 leading-relaxed">Enhanced delivery performance compared to conventional transfection systems</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- APPLICATIONS -->
  <section id="applications" class="fade-section relative py-28 sm:py-36">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="max-w-2xl mb-20">
        <p class="text-brand-600 text-xs font-medium tracking-widest uppercase mb-4">Applications</p>
        <h2 class="font-serif text-4xl sm:text-5xl leading-[1.1] tracking-tight text-warm-950 mb-6">
          Targeting diseases where simpler tools fail
        </h2>
        <p class="text-warm-500 text-lg leading-relaxed">
          Designed for therapeutic challenges that cannot be solved with single-edit approaches.
        </p>
      </div>

      <!-- Editorial list layout instead of cards -->
      <div class="space-y-0 divide-y divide-warm-200">
        <div class="grid md:grid-cols-12 gap-6 md:gap-12 py-12 first:pt-0 group">
          <div class="md:col-span-1">
            <div class="w-10 h-10 rounded-full bg-emerald-50 flex items-center justify-center">
              <div class="w-2.5 h-2.5 rounded-full bg-emerald-500"></div>
            </div>
          </div>
          <div class="md:col-span-4">
            <h3 class="font-serif text-2xl text-warm-900 mb-2">Liver-Directed RNA Medicine</h3>
            <p class="text-warm-500 leading-relaxed">Precision hepatic gene modulation for chronic conditions with high unmet need.</p>
          </div>
          <div class="md:col-span-7">
            <div class="grid sm:grid-cols-3 gap-4 text-sm text-warm-600">
              <div class="bg-warm-100/60 rounded-xl px-5 py-4">Chronic viral diseases (HBV)</div>
              <div class="bg-warm-100/60 rounded-xl px-5 py-4">High-burden protein deficiencies</div>
              <div class="bg-warm-100/60 rounded-xl px-5 py-4">Precision gene modulation</div>
            </div>
          </div>
        </div>

        <div class="grid md:grid-cols-12 gap-6 md:gap-12 py-12 group">
          <div class="md:col-span-1">
            <div class="w-10 h-10 rounded-full bg-violet-50 flex items-center justify-center">
              <div class="w-2.5 h-2.5 rounded-full bg-violet-500"></div>
            </div>
          </div>
          <div class="md:col-span-4">
            <h3 class="font-serif text-2xl text-warm-900 mb-2">Complex Genetic Disorders</h3>
            <p class="text-warm-500 leading-relaxed">Multi-component strategies for diseases beyond the reach of single-edit tools.</p>
          </div>
          <div class="md:col-span-7">
            <div class="grid sm:grid-cols-3 gap-4 text-sm text-warm-600">
              <div class="bg-warm-100/60 rounded-xl px-5 py-4">Large gene insertion</div>
              <div class="bg-warm-100/60 rounded-xl px-5 py-4">Multi-component correction</div>
              <div class="bg-warm-100/60 rounded-xl px-5 py-4">Beyond base &amp; prime editing</div>
            </div>
          </div>
        </div>

        <div class="grid md:grid-cols-12 gap-6 md:gap-12 py-12 group">
          <div class="md:col-span-1">
            <div class="w-10 h-10 rounded-full bg-amber-50 flex items-center justify-center">
              <div class="w-2.5 h-2.5 rounded-full bg-amber-500"></div>
            </div>
