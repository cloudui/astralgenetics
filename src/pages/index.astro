---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Astral Genetics — RNA All-in-One Platform">
  <!-- NAV -->
  <nav class="fixed top-0 w-full z-50 bg-warm-50/80 backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="h-20 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <div
            class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-sm font-semibold text-white"
          >
            AG
          </div>
          <span
            class="text-sm font-medium tracking-wider uppercase text-warm-700"
            >Astral Genetics</span
          >
        </a>
        <div
          class="hidden md:flex items-center gap-10 text-[13px] tracking-wide text-warm-500"
        >
          <a href="#platform" class="hover:text-warm-900 transition-colors"
            >Platform</a
          >
          <a href="#capabilities" class="hover:text-warm-900 transition-colors"
            >Science</a
          >
          <a href="#applications" class="hover:text-warm-900 transition-colors"
            >Applications</a
          >
          <a href="#company" class="hover:text-warm-900 transition-colors"
            >Company</a
          >
          <a
            href="#contact"
            class="ml-2 px-5 py-2 rounded-full bg-brand-600 text-white hover:bg-brand-700 transition-colors"
            >Partner With Us</a
          >
        </div>
        <button
          id="menu-toggle"
          class="md:hidden text-warm-600 hover:text-warm-900"
          aria-label="Menu"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
    <div
      id="mobile-menu"
      class="hidden md:hidden border-t border-warm-200 bg-warm-50/95 backdrop-blur-xl"
    >
      <div class="px-6 py-5 flex flex-col gap-4 text-sm text-warm-600">
        <a href="#platform" class="hover:text-warm-900">Platform</a>
        <a href="#capabilities" class="hover:text-warm-900">Science</a>
        <a href="#applications" class="hover:text-warm-900">Applications</a>
        <a href="#company" class="hover:text-warm-900">Company</a>
        <a
          href="#contact"
          class="mt-2 text-center px-5 py-2.5 rounded-full bg-brand-600 text-white"
          >Partner With Us</a
        >
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section
    class="relative min-h-screen flex items-end overflow-hidden pb-24 pt-32 lg:pt-0 lg:items-center"
  >
    <!-- Background with star field -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-brand-100/50 via-brand-50/30 to-warm-100/40"
    >
    </div>
    <!-- Stars -->
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="star sm" style="top:8%;left:12%;"></div>
      <div class="star" style="top:15%;left:78%;"></div>
      <div class="star sm" style="top:22%;left:45%;"></div>
      <div class="star" style="top:6%;left:62%;"></div>
      <div class="star sm" style="top:30%;left:88%;"></div>
      <div class="star" style="top:18%;left:32%;"></div>
      <div class="star sm" style="top:12%;left:92%;"></div>
      <div class="star bright" style="top:10%;left:55%;"></div>
      <div class="star bright" style="top:25%;left:72%;"></div>
      <div class="star bright" style="top:5%;left:35%;"></div>
      <div class="star" style="top:28%;left:20%;"></div>
      <div class="star sm" style="top:3%;left:80%;"></div>
      <div class="star" style="top:38%;left:68%;"></div>
      <div class="star sm" style="top:42%;left:15%;"></div>
      <div class="star" style="top:50%;left:82%;"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-10 w-full">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Left: text -->
        <div>
          <p
            class="text-brand-600 text-sm font-medium tracking-widest uppercase mb-6"
          >
            RNA Therapeutics Platform
          </p>

          <h1
            class="font-serif text-5xl sm:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-warm-950 mb-8"
          >
            One RNA.<br />
            Multiple functions.<br />
            <em class="text-brand-600">Real medicine.</em>
          </h1>

          <p class="text-lg text-warm-700 max-w-lg leading-relaxed mb-10">
            A proprietary platform that integrates multiple gene editing and
            regulatory components into a single, deliverable RNA molecule —
            paired with large-fragment delivery systems engineered to overcome
            the limits of conventional genetic medicine.
          </p>

          <div class="flex flex-wrap gap-4">
            <a
              href="#platform"
              class="px-7 py-3.5 rounded-full bg-brand-600 text-white font-medium hover:bg-brand-700 transition-all hover:shadow-lg hover:shadow-brand-200"
            >
              Explore Platform
            </a>
            <a
              href="#capabilities"
              class="px-7 py-3.5 rounded-full border border-warm-300 text-warm-600 hover:border-warm-400 hover:text-warm-800 font-medium transition-all"
            >
              View Science
            </a>
          </div>
        </div>

        <!-- Right: hero illustration — RNA helix within a constellation/orbital field -->
        <div class="hidden lg:flex items-center justify-center">
          <div class="relative w-full max-w-md aspect-square">
            <!-- Soft nebula glow -->
            <div
              class="absolute inset-8 bg-brand-200/30 rounded-full blur-[80px]"
            >
            </div>
            <div
              class="absolute top-12 right-8 w-40 h-40 bg-brand-100/40 rounded-full blur-[50px]"
            >
            </div>

            <svg
              class="relative w-full h-full"
              viewBox="0 0 400 400"
              fill="none"
            >
              <defs>
                <linearGradient id="helix1" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop
                    offset="0%"
                    stop-color="currentColor"
                    stop-opacity="0.2"
                    class="text-brand-400"></stop>
                  <stop
                    offset="50%"
                    stop-color="currentColor"
                    stop-opacity="0.7"
                    class="text-brand-600"></stop>
                  <stop
                    offset="100%"
                    stop-color="currentColor"
                    stop-opacity="0.2"
                    class="text-brand-400"></stop>
                </linearGradient>
                <linearGradient id="helix2" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop
                    offset="0%"
                    stop-color="currentColor"
                    stop-opacity="0.15"
                    class="text-brand-300"></stop>
                  <stop
                    offset="50%"
                    stop-color="currentColor"
                    stop-opacity="0.5"
                    class="text-brand-500"></stop>
                  <stop
                    offset="100%"
                    stop-color="currentColor"
                    stop-opacity="0.15"
                    class="text-brand-300"></stop>
                </linearGradient>
                <radialGradient id="starglow">
                  <stop
                    offset="0%"
                    stop-color="currentColor"
                    stop-opacity="0.6"
                    class="text-brand-300"></stop>
                  <stop
                    offset="100%"
                    stop-color="currentColor"
                    stop-opacity="0"
                    class="text-brand-300"></stop>
                </radialGradient>
              </defs>

              <!-- Constellation lines (connecting stars around the helix) -->
              <g class="text-brand-300" opacity="0.3">
                <line
                  x1="60"
                  y1="55"
                  x2="120"
                  y2="90"
                  stroke="currentColor"
                  stroke-width="0.5"></line>
                <line
                  x1="120"
                  y1="90"
                  x2="85"
                  y2="160"
                  stroke="currentColor"
                  stroke-width="0.5"></line>
                <line
                  x1="330"
                  y1="80"
                  x2="290"
                  y2="140"
                  stroke="currentColor"
                  stroke-width="0.5"></line>
                <line
                  x1="290"
                  y1="140"
                  x2="340"
                  y2="200"
                  stroke="currentColor"
                  stroke-width="0.5"></line>
                <line
                  x1="340"
                  y1="200"
                  x2="310"
                  y2="280"
                  stroke="currentColor"
                  stroke-width="0.5"></line>
                <line
                  x1="70"
                  y1="300"
                  x2="110"
                  y2="250"
                  stroke="currentColor"
                  stroke-width="0.5"></line>
                <line
                  x1="110"
                  y1="250"
                  x2="85"
                  y2="160"
                  stroke="currentColor"
                  stroke-width="0.5"></line>
                <line
                  x1="310"
                  y1="280"
                  x2="340"
                  y2="340"
                  stroke="currentColor"
                  stroke-width="0.5"></line>
                <line
                  x1="60"
                  y1="55"
                  x2="50"
                  y2="120"
                  stroke="currentColor"
                  stroke-width="0.5"></line>
                <line
                  x1="50"
                  y1="120"
                  x2="85"
                  y2="160"
                  stroke="currentColor"
                  stroke-width="0.5"></line>
              </g>

              <!-- Constellation star points -->
              <g class="text-brand-500">
                <circle cx="60" cy="55" r="2" fill="currentColor" opacity="0.5"
                ></circle>
                <circle
                  cx="120"
                  cy="90"
                  r="1.5"
                  fill="currentColor"
                  opacity="0.4"></circle>
                <circle cx="85" cy="160" r="2" fill="currentColor" opacity="0.5"
                ></circle>
                <circle
                  cx="330"
                  cy="80"
                  r="1.5"
                  fill="currentColor"
                  opacity="0.4"></circle>
                <circle
                  cx="290"
                  cy="140"
                  r="2"
                  fill="currentColor"
                  opacity="0.5"></circle>
                <circle
                  cx="340"
                  cy="200"
                  r="1.5"
                  fill="currentColor"
                  opacity="0.4"></circle>
                <circle
                  cx="310"
                  cy="280"
                  r="2"
                  fill="currentColor"
                  opacity="0.5"></circle>
                <circle
                  cx="340"
                  cy="340"
                  r="1.5"
                  fill="currentColor"
                  opacity="0.3"></circle>
                <circle
                  cx="70"
                  cy="300"
                  r="1.5"
                  fill="currentColor"
                  opacity="0.4"></circle>
                <circle
                  cx="110"
                  cy="250"
                  r="2"
                  fill="currentColor"
                  opacity="0.5"></circle>
                <circle
                  cx="50"
                  cy="120"
                  r="1.5"
                  fill="currentColor"
                  opacity="0.3"></circle>
              </g>

              <!-- Star glows (larger faint circles behind key stars) -->
              <circle cx="60" cy="55" r="8" fill="url(#starglow)"></circle>
              <circle cx="290" cy="140" r="10" fill="url(#starglow)"></circle>
              <circle cx="110" cy="250" r="8" fill="url(#starglow)"></circle>

              <!-- Orbital rings around helix -->
              <ellipse
                cx="200"
                cy="200"
                rx="175"
                ry="60"
                stroke="currentColor"
                stroke-width="0.5"
                opacity="0.12"
                class="text-brand-400"
                transform="rotate(-20 200 200)"></ellipse>
              <ellipse
                cx="200"
                cy="200"
                rx="160"
                ry="50"
                stroke="currentColor"
                stroke-width="0.5"
                opacity="0.08"
                class="text-brand-400"
                transform="rotate(15 200 200)"
                stroke-dasharray="3 5"></ellipse>

              <!-- Central helix strands -->
              <path
                d="M170,50 Q265,95 170,150 Q75,205 170,260 Q265,315 170,370"
                stroke="url(#helix1)"
                stroke-width="2"
                fill="none"></path>
              <path
                d="M230,50 Q135,95 230,150 Q325,205 230,260 Q135,315 230,370"
                stroke="url(#helix2)"
                stroke-width="2"
                fill="none"></path>

              <!-- Base pair rungs -->
              <g class="text-brand-300" opacity="0.4">
                <line
                  x1="182"
                  y1="68"
                  x2="218"
                  y2="68"
                  stroke="currentColor"
                  stroke-width="1"></line>
                <line
                  x1="160"
                  y1="115"
                  x2="240"
                  y2="115"
                  stroke="currentColor"
                  stroke-width="1"></line>
                <line
                  x1="178"
                  y1="162"
                  x2="222"
                  y2="162"
                  stroke="currentColor"
                  stroke-width="1"></line>
                <line
                  x1="160"
                  y1="210"
                  x2="240"
                  y2="210"
                  stroke="currentColor"
                  stroke-width="1"></line>
                <line
                  x1="182"
                  y1="258"
                  x2="218"
                  y2="258"
                  stroke="currentColor"
                  stroke-width="1"></line>
                <line
                  x1="160"
                  y1="305"
                  x2="240"
                  y2="305"
                  stroke="currentColor"
                  stroke-width="1"></line>
                <line
                  x1="182"
                  y1="350"
                  x2="218"
                  y2="350"
                  stroke="currentColor"
                  stroke-width="1"></line>
              </g>

              <!-- Functional module nodes on helix -->
              <circle
                cx="170"
                cy="150"
                r="16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                opacity="0.5"
                class="text-brand-500"></circle>
              <circle
                cx="170"
                cy="150"
                r="4"
                fill="currentColor"
                opacity="0.6"
                class="text-brand-600"></circle>

              <circle
                cx="230"
                cy="210"
                r="20"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                opacity="0.5"
                class="text-brand-500"></circle>
              <circle
                cx="230"
                cy="210"
                r="5"
                fill="currentColor"
                opacity="0.6"
                class="text-brand-600"></circle>

              <circle
                cx="170"
                cy="260"
                r="14"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                opacity="0.5"
                class="text-brand-500"></circle>
              <circle
                cx="170"
                cy="260"
                r="3.5"
                fill="currentColor"
                opacity="0.6"
                class="text-brand-600"></circle>

              <!-- Twinkling particles drifting slowly -->
              <circle
                cx="320"
                cy="120"
                r="1.5"
                fill="currentColor"
                opacity="0.4"
                class="text-brand-400"
              >
                <animate
                  attributeName="opacity"
                  values="0.4;0.15;0.4"
                  dur="4s"
                  repeatCount="indefinite"></animate>
              </circle>
              <circle
                cx="80"
                cy="280"
                r="1"
                fill="currentColor"
                opacity="0.3"
                class="text-brand-400"
              >
                <animate
                  attributeName="opacity"
                  values="0.3;0.1;0.3"
                  dur="5s"
                  repeatCount="indefinite"></animate>
              </circle>
              <circle
                cx="350"
                cy="310"
                r="1.5"
                fill="currentColor"
                opacity="0.3"
                class="text-brand-300"
              >
                <animate
                  attributeName="opacity"
                  values="0.3;0.1;0.3"
                  dur="6s"
                  repeatCount="indefinite"></animate>
              </circle>
              <circle
                cx="55"
                cy="90"
                r="1"
                fill="currentColor"
                opacity="0.25"
                class="text-brand-400"
              >
                <animate
                  attributeName="opacity"
                  values="0.25;0.08;0.25"
                  dur="3.5s"
                  repeatCount="indefinite"></animate>
              </circle>
              <circle
                cx="200"
                cy="30"
                r="1"
                fill="currentColor"
                opacity="0.3"
                class="text-brand-400"
              >
                <animate
                  attributeName="opacity"
                  values="0.3;0.1;0.3"
                  dur="4.5s"
                  repeatCount="indefinite"></animate>
              </circle>
              <circle
                cx="200"
                cy="380"
                r="1"
                fill="currentColor"
                opacity="0.2"
                class="text-brand-400"
              >
                <animate
                  attributeName="opacity"
                  values="0.2;0.05;0.2"
                  dur="5.5s"
                  repeatCount="indefinite"></animate>
              </circle>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="h-px bg-warm-200"></div>
  </div>

  <!-- PLATFORM OVERVIEW -->
  <section id="platform" class="fade-section relative py-28 sm:py-36">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-12 gap-16 lg:gap-20">
        <div class="lg:col-span-5">
          <p
            class="text-brand-600 text-xs font-medium tracking-widest uppercase mb-4"
          >
            Platform
          </p>
          <h2
            class="font-serif text-4xl sm:text-5xl leading-[1.1] tracking-tight text-warm-950 mb-6"
          >
            A new architecture for genetic medicine
          </h2>
          <p class="text-warm-700 text-lg leading-relaxed">
            Traditional approaches fragment complexity across multiple delivery
            vectors and editing systems. Our platform unifies them into a single
            molecule.
          </p>
        </div>

        <div class="lg:col-span-7 space-y-8">
          <div
            class="relative border border-warm-200 rounded-2xl bg-white p-8 sm:p-10"
          >
            <div class="flex items-start gap-6">
              <div
                class="shrink-0 w-14 h-14 rounded-2xl bg-brand-50 flex items-center justify-center"
              >
                <svg
                  class="w-7 h-7 text-brand-600"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"
                  ></path>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="font-serif text-2xl text-warm-900 mb-3">
                  RNA All-in-One
                </h3>
                <p class="text-warm-600 leading-relaxed mb-5">
                  A single IVT RNA encoding all required functional components
                  for coordinated therapeutic action.
                </p>
                <div class="grid sm:grid-cols-3 gap-4 text-sm text-warm-600">
                  <div class="flex items-start gap-2">
                    <span
                      class="mt-2.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"
                    ></span>
                    Multi-component integration in one transcript
                  </div>
                  <div class="flex items-start gap-2">
                    <span
                      class="mt-2.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"
                    ></span>
                    Synchronized intracellular release
                  </div>
                  <div class="flex items-start gap-2">
                    <span
                      class="mt-2.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"
                    ></span>
                    Reduced variability
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div
            class="relative border border-warm-200 rounded-2xl bg-white p-8 sm:p-10"
          >
            <div class="flex items-start gap-6">
              <div
                class="shrink-0 w-14 h-14 rounded-2xl bg-brand-50 flex items-center justify-center"
              >
                <svg
                  class="w-7 h-7 text-brand-600"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"
                  ></path>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="font-serif text-2xl text-warm-900 mb-3">
                  Large-Payload LNP Engine
                </h3>
                <p class="text-warm-600 leading-relaxed mb-5">
                  A delivery system purpose-built for next-generation RNA
                  therapeutics.
                </p>
                <div class="grid sm:grid-cols-3 gap-4 text-sm text-warm-600">
                  <div class="flex items-start gap-2">
                    <span
                      class="mt-2.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"
                    ></span>
                    Large RNA payloads (9kb+)
                  </div>
                  <div class="flex items-start gap-2">
                    <span
                      class="mt-2.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"
                    ></span>
                    Hepatic targeting &amp; systemic delivery
                  </div>
                  <div class="flex items-start gap-2">
                    <span
                      class="mt-2.5 w-1 h-1 rounded-full bg-brand-400 shrink-0"
                    ></span>
                    Scalable for clinical translation
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section
    class="fade-section relative py-28 sm:py-36 bg-brand-50/40 overflow-hidden"
  >
    <!-- Stars and small planet -->
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="star sm" style="top:15%;left:5%;"></div>
      <div class="star" style="top:70%;left:90%;"></div>
      <div class="star bright" style="top:40%;left:95%;"></div>
      <div class="star sm" style="top:85%;left:15%;"></div>
      <div class="star" style="top:25%;left:80%;"></div>
      <div class="star sm" style="top:55%;left:3%;"></div>
      <div class="star" style="top:10%;left:60%;"></div>
      <div class="star sm" style="top:90%;left:75%;"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-10">
      <p
        class="text-brand-600 text-xs font-medium tracking-widest uppercase mb-4"
      >
        Process
      </p>
      <h2
        class="font-serif text-4xl sm:text-5xl leading-[1.1] tracking-tight text-warm-950 mb-20"
      >
        From design to execution
      </h2>

      <div
        class="grid md:grid-cols-3 gap-px bg-warm-200 rounded-2xl overflow-hidden"
      >
        <div class="bg-white p-10 sm:p-12">
          <div class="font-serif text-6xl text-brand-200 mb-6">1</div>
          <h3 class="font-serif text-2xl text-warm-900 mb-3">Encode</h3>
          <p class="text-warm-600 leading-relaxed">
            Multiple functional elements are designed within a single RNA
            construct, enabling coordinated multi-component activity from one
            molecule.
          </p>
        </div>
        <div class="bg-white p-10 sm:p-12">
          <div class="font-serif text-6xl text-brand-200 mb-6">2</div>
          <h3 class="font-serif text-2xl text-warm-900 mb-3">Deliver</h3>
          <p class="text-warm-600 leading-relaxed">
