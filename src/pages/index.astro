<style>
  /* 4-point star shape for light backgrounds */
  .star {
    position: absolute;
    width: 8px;
    height: 8px;
    opacity: 0.25;
    animation: twinkle 4s ease-in-out infinite;
  }

  .star::before {
    content: "";
    position: absolute;
    inset: 0;
    background: #7a9fcb;
    clip-path: polygon(
      50% 0%,
      60% 40%,
      100% 50%,
      60% 60%,
      50% 100%,
      40% 60%,
      0% 50%,
      40% 40%
    );
  }

  .star.bright {
    width: 12px;
    height: 12px;
    opacity: 0.35;
    filter: drop-shadow(0 0 3px rgba(122, 159, 203, 0.4));
  }

  .star.sm {
    width: 5px;
    height: 5px;
    opacity: 0.15;
  }

  /* 4-point star for dark backgrounds */
  .star-light {
    position: absolute;
    width: 8px;
    height: 8px;
    opacity: 0.35;
    animation: twinkle 4s ease-in-out infinite;
  }

  .star-light::before {
    content: "";
    position: absolute;
    inset: 0;
    background: white;
    clip-path: polygon(
      50% 0%,
      60% 40%,
      100% 50%,
      60% 60%,
      50% 100%,
      40% 60%,
      0% 50%,
      40% 40%
    );
  }

  .star-light.bright {
    width: 14px;
    height: 14px;
    opacity: 0.5;
    filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.3));
  }

  .star-light.sm {
    width: 5px;
    height: 5px;
    opacity: 0.18;
  }

  /* Stagger twinkle timings */
  .star:nth-child(2n),
  .star-light:nth-child(2n) {
    animation-delay: -1.5s;
  }
  .star:nth-child(3n),
  .star-light:nth-child(3n) {
    animation-delay: -2.8s;
  }
  .star:nth-child(5n),
  .star-light:nth-child(5n) {
    animation-delay: -0.7s;
  }
  .star:nth-child(7n),
  .star-light:nth-child(7n) {
    animation-delay: -3.3s;
  }
  .star:nth-child(4n),
  .star-light:nth-child(4n) {
    animation-duration: 5s;
  }
  .star:nth-child(6n),
  .star-light:nth-child(6n) {
    animation-duration: 6s;
  }
  .star:nth-child(8n),
  .star-light:nth-child(8n) {
    animation-duration: 7s;
    animation-delay: -2s;
  }

  @keyframes twinkle {
    0%,
    100% {
      opacity: var(--tw-opacity, 0.2);
    }
    50% {
      opacity: 0.04;
    }
  }

  .star.bright {
    --tw-opacity: 0.3;
  }
  .star-light {
    --tw-opacity: 0.3;
  }
  .star-light.bright {
    --tw-opacity: 0.5;
  }
</style>

<script>
  // Mobile menu
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => menu?.classList.toggle("hidden"));
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => menu?.classList.add("hidden"));
  });

  // Scroll-triggered fade-in
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
        }
      });
    },
    { threshold: 0.1 },
  );

  document
    .querySelectorAll(".fade-section")
    .forEach((el) => observer.observe(el));
</script>
