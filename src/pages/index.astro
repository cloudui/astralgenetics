---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Astral Genetics — RNA All-in-One Platform">
  <!-- NAV -->
  <nav class="fixed top-0 w-full z-50 border-b border-white/5 bg-midnight-950/80 backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center text-sm font-bold tracking-tight">AG</div>
        <span class="text-sm font-semibold tracking-wide uppercase text-white/90 group-hover:text-white transition-colors">Astral Genetics</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm text-white/60">
        <a href="#platform" class="hover:text-white transition-colors">Platform</a>
        <a href="#capabilities" class="hover:text-white transition-colors">Capabilities</a>
        <a href="#applications" class="hover:text-white transition-colors">Applications</a>
        <a href="#company" class="hover:text-white transition-colors">Company</a>
        <a href="#contact" class="px-4 py-1.5 rounded-full border border-brand-500/40 text-brand-400 hover:bg-brand-500/10 transition-all">Partner With Us</a>
      </div>
      <!-- Mobile menu button -->
      <button id="menu-toggle" class="md:hidden text-white/60 hover:text-white" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-midnight-950/95 backdrop-blur-xl">
      <div class="px-6 py-4 flex flex-col gap-3 text-sm text-white/60">
        <a href="#platform" class="hover:text-white py-1">Platform</a>
        <a href="#capabilities" class="hover:text-white py-1">Capabilities</a>
        <a href="#applications" class="hover:text-white py-1">Applications</a>
        <a href="#company" class="hover:text-white py-1">Company</a>
        <a href="#contact" class="mt-2 text-center px-4 py-2 rounded-full border border-brand-500/40 text-brand-400 hover:bg-brand-500/10 transition-all">Partner With Us</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background effects -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-b from-brand-950/30 via-midnight-950 to-midnight-950"></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-brand-500/5 rounded-full blur-[120px]"></div>
      <div class="absolute top-1/4 right-1/4 w-[300px] h-[300px] bg-brand-600/5 rounded-full blur-[80px]"></div>
      <!-- Grid pattern -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
      <!-- DNA helix decoration -->
      <svg class="absolute right-[10%] top-[15%] w-48 h-96 opacity-[0.06] text-brand-400" viewBox="0 0 100 400" fill="none" stroke="currentColor" stroke-width="1">
        <path d="M20,0 Q80,50 20,100 Q-40,150 20,200 Q80,250 20,300 Q-40,350 20,400" />
        <path d="M80,0 Q20,50 80,100 Q140,150 80,200 Q20,250 80,300 Q140,350 80,400" />
        <line x1="35" y1="25" x2="65" y2="25" opacity="0.5" />
        <line x1="25" y1="75" x2="75" y2="75" opacity="0.5" />
        <line x1="35" y1="125" x2="65" y2="125" opacity="0.5" />
        <line x1="25" y1="175" x2="75" y2="175" opacity="0.5" />
        <line x1="35" y1="225" x2="65" y2="225" opacity="0.5" />
        <line x1="25" y1="275" x2="75" y2="275" opacity="0.5" />
        <line x1="35" y1="325" x2="65" y2="325" opacity="0.5" />
        <line x1="25" y1="375" x2="75" y2="375" opacity="0.5" />
      </svg>
    </div>

    <div class="relative max-w-4xl mx-auto px-6 pt-24 pb-16 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-500/20 bg-brand-500/5 text-brand-400 text-xs font-medium tracking-wide uppercase mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse"></span>
        RNA All-in-One Platform
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.1] tracking-tight mb-6">
        One RNA. Multiple Functions.<br />
        <span class="bg-gradient-to-r from-brand-400 to-brand-600 bg-clip-text text-transparent">Real Genetic Medicine.</span>
      </h1>

      <p class="text-lg sm:text-xl text-white/50 max-w-2xl mx-auto mb-4 leading-relaxed">
        A proprietary platform that integrates multiple gene editing and regulatory components into a single, deliverable RNA molecule.
      </p>

      <p class="text-sm text-white/30 font-mono mb-10">
        From multi-vector complexity → single-molecule precision
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#platform" class="px-6 py-3 rounded-lg bg-brand-600 hover:bg-brand-500 text-white font-medium transition-all hover:shadow-lg hover:shadow-brand-500/20">
          Explore Platform
        </a>
        <a href="#capabilities" class="px-6 py-3 rounded-lg border border-white/10 text-white/70 hover:text-white hover:border-white/20 font-medium transition-all">
          View Technology
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/20">
      <span class="text-xs tracking-widest uppercase">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-white/20 to-transparent"></div>
    </div>
  </section>

  <!-- PLATFORM OVERVIEW -->
  <section id="platform" class="relative py-24 sm:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-2xl mb-16">
        <p class="text-brand-400 text-sm font-medium tracking-wide uppercase mb-3">Platform</p>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">A New Architecture for Genetic Medicine</h2>
        <p class="text-white/40 text-lg">Traditional approaches fragment complexity across multiple systems. We unify them.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- RNA All-in-One -->
        <div class="group relative rounded-2xl border border-white/5 bg-white/[0.02] p-8 hover:border-brand-500/20 hover:bg-white/[0.03] transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-brand-500/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">RNA All-in-One Platform</h3>
          <p class="text-white/40 mb-6 leading-relaxed">A single IVT RNA encoding all required functional components for coordinated therapeutic action.</p>
          <ul class="space-y-3 text-sm text-white/50">
            <li class="flex items-start gap-2.5">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-500 shrink-0"></span>
              Multi-component integration in one transcript
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-500 shrink-0"></span>
              Synchronized intracellular release and activity
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-500 shrink-0"></span>
              Reduced variability, improved consistency
            </li>
          </ul>
        </div>

        <!-- LNP Engine -->
        <div class="group relative rounded-2xl border border-white/5 bg-white/[0.02] p-8 hover:border-brand-500/20 hover:bg-white/[0.03] transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-brand-500/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Large-Payload LNP Engine</h3>
          <p class="text-white/40 mb-6 leading-relaxed">A delivery system purpose-built for next-generation RNA therapeutics.</p>
          <ul class="space-y-3 text-sm text-white/50">
            <li class="flex items-start gap-2.5">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-500 shrink-0"></span>
              Efficient delivery of large RNA payloads (9kb+)
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-500 shrink-0"></span>
              Optimized for hepatic targeting and systemic administration
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-500 shrink-0"></span>
              Scalable formulation for clinical translation
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="relative py-24 sm:py-32 border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-2xl mb-16">
        <p class="text-brand-400 text-sm font-medium tracking-wide uppercase mb-3">Process</p>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">From Design to Execution — In One System</h2>
      </div>

      <div class="grid sm:grid-cols-3 gap-8">
        <div class="relative">
          <div class="text-5xl font-bold text-white/[0.04] mb-4 font-mono">01</div>
          <h3 class="text-lg font-semibold mb-2 -mt-4">Encode</h3>
          <p class="text-white/40 text-sm leading-relaxed">Multiple functional elements are designed within a single RNA construct, enabling coordinated multi-component activity.</p>
        </div>
        <div class="relative">
          <div class="text-5xl font-bold text-white/[0.04] mb-4 font-mono">02</div>
          <h3 class="text-lg font-semibold mb-2 -mt-4">Deliver</h3>
          <p class="text-white/40 text-sm leading-relaxed">Proprietary LNP systems transport large RNA payloads into target tissues with high efficiency and specificity.</p>
        </div>
        <div class="relative">
          <div class="text-5xl font-bold text-white/[0.04] mb-4 font-mono">03</div>
          <h3 class="text-lg font-semibold mb-2 -mt-4">Execute</h3>
          <p class="text-white/40 text-sm leading-relaxed">Intracellular processing releases independent modules, enabling coordinated biological function from a single delivery event.</p>
        </div>
      </div>

      <!-- Connecting line -->
      <div class="hidden sm:block relative mt-4">
        <div class="absolute top-0 left-[16.67%] right-[16.67%] h-px bg-gradient-to-r from-transparent via-brand-500/20 to-transparent"></div>
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section id="capabilities" class="relative py-24 sm:py-32 border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-2xl mb-16">
        <p class="text-brand-400 text-sm font-medium tracking-wide uppercase mb-3">Capabilities</p>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">A Versatile Engine for Genetic Modulation</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-7">
          <div class="text-brand-400 text-xs font-mono tracking-wider uppercase mb-4">Epigenetic Editing</div>
          <h3 class="text-lg font-semibold mb-3">CRISPRi / Modulation</h3>
          <p class="text-white/40 text-sm mb-5 leading-relaxed">Programmable, non-permanent control of gene expression without altering the DNA sequence.</p>
          <ul class="space-y-2 text-sm text-white/50">
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-500/60 shrink-0"></span>
              Multi-target silencing within a single construct
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-500/60 shrink-0"></span>
              Tumor and viral transcriptional reprogramming
            </li>
          </ul>
        </div>

        <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-7">
          <div class="text-brand-400 text-xs font-mono tracking-wider uppercase mb-4">Genome Editing</div>
          <h3 class="text-lg font-semibold mb-3">Large Fragment Integration</h3>
          <p class="text-white/40 text-sm mb-5 leading-relaxed">Efficient modification beyond single-base editing, supporting complex genetic corrections.</p>
          <ul class="space-y-2 text-sm text-white/50">
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-500/60 shrink-0"></span>
              Supports large genetic insertions
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-500/60 shrink-0"></span>
              Enables correction of complex mutations
            </li>
          </ul>
        </div>

        <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-7">
          <div class="text-brand-400 text-xs font-mono tracking-wider uppercase mb-4">Protein Replacement</div>
          <h3 class="text-lg font-semibold mb-3">In Vivo RNA Expression</h3>
          <p class="text-white/40 text-sm mb-5 leading-relaxed">Direct expression of functional proteins via high-expression IVT RNA constructs.</p>
          <ul class="space-y-2 text-sm text-white/50">
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-500/60 shrink-0"></span>
              High-expression IVT RNA constructs
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-brand-500/60 shrink-0"></span>
              Therapeutic delivery beyond AAV limits
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- VALIDATION / STATS -->
  <section class="relative py-24 sm:py-32 border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6">
      <div class="rounded-2xl border border-white/5 bg-gradient-to-br from-brand-950/40 to-midnight-900/20 p-8 sm:p-12">
        <p class="text-brand-400 text-sm font-medium tracking-wide uppercase mb-3">Validation</p>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-8">Engineered for Real-World Performance</h2>

        <div class="grid sm:grid-cols-3 gap-8">
          <div>
            <div class="text-3xl font-bold text-brand-400 mb-2">>9 kb</div>
            <p class="text-white/40 text-sm leading-relaxed">Successfully delivered large RNA constructs exceeding conventional payload limits</p>
          </div>
          <div>
            <div class="text-3xl font-bold text-brand-400 mb-2">Multi-component</div>
            <p class="text-white/40 text-sm leading-relaxed">Demonstrated coordinated expression from a single transcript</p>
          </div>
          <div>
            <div class="text-3xl font-bold text-brand-400 mb-2">Enhanced delivery</div>
            <p class="text-white/40 text-sm leading-relaxed">Superior performance compared to conventional transfection systems</p>
          </div>
        </div>

        <p class="text-white/30 text-sm mt-8 pt-6 border-t border-white/5">Our platform is built not only for innovation—but for translatability.</p>
      </div>
    </div>
  </section>

  <!-- APPLICATIONS -->
  <section id="applications" class="relative py-24 sm:py-32 border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-2xl mb-16">
        <p class="text-brand-400 text-sm font-medium tracking-wide uppercase mb-3">Applications</p>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Targeting Diseases Where Simpler Tools Fail</h2>
        <p class="text-white/40 text-lg">Designed for problems that cannot be solved with single-edit approaches.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="group rounded-2xl border border-white/5 bg-white/[0.02] p-7 hover:border-brand-500/15 transition-all duration-300">
          <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-3">Liver-Directed RNA Medicine</h3>
          <ul class="space-y-2 text-sm text-white/50">
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-emerald-500/60 shrink-0"></span>
              Chronic viral diseases (e.g., HBV)
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-emerald-500/60 shrink-0"></span>
              High-burden protein deficiencies
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-emerald-500/60 shrink-0"></span>
              Precision hepatic gene modulation
            </li>
          </ul>
        </div>

        <div class="group rounded-2xl border border-white/5 bg-white/[0.02] p-7 hover:border-brand-500/15 transition-all duration-300">
          <div class="w-10 h-10 rounded-lg bg-violet-500/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.491 48.491 0 0 1-4.163-.3c.186 1.613.466 3.193.834 4.73.878-.052 1.77-.08 2.672-.08h2.172c.903 0 1.794.028 2.672.08.368-1.537.648-3.117.834-4.73a48.28 48.28 0 0 1-4.163.3.64.64 0 0 1-.657-.643v0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 10.5c1.768 5.105 4.186 9.592 7.098 13.195.19.234.499.305.752.305s.563-.071.752-.305C17.564 20.092 19.982 15.605 21.75 10.5" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-3">High-Complexity Genetic Disorders</h3>
          <ul class="space-y-2 text-sm text-white/50">
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-violet-500/60 shrink-0"></span>
              Diseases requiring large gene insertion
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-violet-500/60 shrink-0"></span>
              Multi-component correction strategies
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-violet-500/60 shrink-0"></span>
              Beyond base and prime editing limits
            </li>
          </ul>
        </div>

        <div class="group rounded-2xl border border-white/5 bg-white/[0.02] p-7 hover:border-brand-500/15 transition-all duration-300">
          <div class="w-10 h-10 rounded-lg bg-amber-500/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0 1 16.5 7.605" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-3">Precision Oncology</h3>
          <ul class="space-y-2 text-sm text-white/50">
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-amber-500/60 shrink-0"></span>
              Epigenetic reprogramming of tumor pathways
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-amber-500/60 shrink-0"></span>
              Tumor microenvironment modulation
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-amber-500/60 shrink-0"></span>
              Multi-target intervention, single therapy
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- PARTNERSHIP CTA -->
  <section id="contact" class="relative py-24 sm:py-32 border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6">
      <div class="relative rounded-2xl border border-brand-500/10 overflow-hidden">
        <!-- Background -->
        <div class="absolute inset-0 bg-gradient-to-br from-brand-950/60 via-midnight-900/40 to-midnight-950"></div>
        <div class="absolute top-0 right-0 w-96 h-96 bg-brand-500/5 rounded-full blur-[100px]"></div>

        <div class="relative p-8 sm:p-12 lg:p-16">
          <div class="max-w-2xl">
            <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Partner With Astral Genetics</h2>
            <p class="text-white/40 text-lg mb-8 leading-relaxed">
              We collaborate with leading biopharma and research organizations to unlock new therapeutic possibilities through multi-component genetic engineering, large payload delivery, and strategies beyond conventional CRISPR.
